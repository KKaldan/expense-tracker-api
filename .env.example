NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/expense_tracker

# JWT — use a long random string for JWT_SECRET (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-256-bit-random-secret
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# Cookie signing — required for refresh token feature (Week 3+)
COOKIE_SECRET=replace-with-cookie-secret
